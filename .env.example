# Copy to .env and adjust.  cp .env.example .env

# --- Source API (hello-world flow pulls users from here) ---
API_BASE_URL=https://jsonplaceholder.typicode.com

# --- Data layout (medallion). Container paths. ---
DATA_DIR=/app/data
DUCKDB_PATH=/app/data/warehouse.duckdb

# --- JupyterLab ---
# Token you use to log into JupyterLab from another machine.
JUPYTER_TOKEN=change-me-please

# --- OpenTelemetry (app side) ---
OTEL_SERVICE_NAME=data-platform
DEPLOYMENT_ENVIRONMENT=dev
# Apps send to the local collector inside the compose network.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- SigNoz (collector -> SigNoz forwarding) ---
# Self-hosted SigNoz on the same host:
SIGNOZ_OTLP_ENDPOINT=host.docker.internal:4317
SIGNOZ_OTLP_INSECURE=true
SIGNOZ_INGESTION_KEY=
# SigNoz Cloud example (uncomment + fill):
# SIGNOZ_OTLP_ENDPOINT=ingest.us.signoz.cloud:443
# SIGNOZ_OTLP_INSECURE=false
# SIGNOZ_INGESTION_KEY=your-ingestion-key

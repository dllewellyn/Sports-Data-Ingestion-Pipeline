# Copy to .env and adjust.  cp .env.example .env

# --- Compose wiring: pick ONE mode ---
# The base docker-compose.yml is environment-neutral; an overlay decides where
# telemetry goes. (Separator is ":" on macOS/Linux, ";" on Windows.)
#
# DEV  — apps + self-hosted SigNoz (full stack, UI on http://localhost:8080):
COMPOSE_FILE=docker-compose.yml:docker-compose.signoz.yml
# PROD — apps only, export to an external collector (set the endpoint below):
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
# REMOTE — apps connected to sports-gaming-engine infrastructure on remote machine:
# COMPOSE_FILE=docker-compose.yml:docker-compose.remote.yml
# DAGSTER_UI_PORT=3002

# --- Source API (hello-world flow pulls users from here) ---
API_BASE_URL=https://jsonplaceholder.typicode.com

# --- Data layout (medallion). Container paths. ---
DATA_DIR=/app/data
DUCKDB_PATH=/app/data/warehouse.duckdb

# DuckDB memory bounds for dbt build (read by dbt/data_platform/profiles.yml).
# Cap memory_limit BELOW what the host can guarantee so DuckDB spills to
# $DATA_DIR/.duckdb_tmp instead of hitting an OS "Allocation failure". Raise on a
# bigger box; lower on the shared home server if dbt still OOMs.
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_MAX_TEMP_SIZE=20GB

# --- JupyterLab ---
# Token you use to log into JupyterLab from another machine.
JUPYTER_TOKEN=change-me-please

# --- OpenTelemetry (app side) ---
OTEL_SERVICE_NAME=data-platform
DEPLOYMENT_ENVIRONMENT=dev
# Used by the PROD overlay only (dev sends to the in-stack SigNoz collector).
# Point this at your already-running external collector:
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.internal:4317

# --- Self-hosted SigNoz (DEV overlay only; ignored in prod) ---
# Pinned image tags for the vendored SigNoz stack (docker-compose.signoz.yml).
# Bump together with the ./signoz/** config files when upgrading.
VERSION=v0.116.1
OTELCOL_TAG=v0.144.2
# JWT secret for the SigNoz app. Dev default is fine locally; change for anything
# exposed beyond localhost.
SIGNOZ_JWT_SECRET=change-me-please

# --- DuckLake catalog ---
# PostgreSQL-backed DuckLake catalog. The catalog Postgres container is defined in
# docker-compose.yml (base) and is shared by all overlays.
# Override these if running with an external Postgres catalog.
POSTGRES_CATALOG_URL="postgres:dbname=ducklake user=ducklake password=ducklake host=ducklake-catalog port=5432"
# Host-side path for DuckLake-managed Parquet files (mapped into containers as /app/data/lake).
DUCKLAKE_DATA_PATH=data/lake

# --- Matchbook Events REST API (bronze ingest, Spec 004) ---
# Credentials from the sports-gaming-engine .env. Required for the matchbook_ingestion job.
MATCHBOOK_USERNAME=your-matchbook-username
MATCHBOOK_PASSWORD=your-matchbook-password

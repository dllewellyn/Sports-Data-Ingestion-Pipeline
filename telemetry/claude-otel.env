# Source this before launching Claude Code so it exports telemetry to the local stack:
#
#     source ./claude-otel.env && claude
#
# These point at the collector exposed by docker-compose on localhost.

# --- Core ---
export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# Host port 14317 (mapped to the collector's 4317) to avoid clashing with an
# existing OTLP stack such as SigNoz already bound to 4317.
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14317

# Prometheus needs cumulative temporality (Claude's default is delta).
export OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# Faster flush for local/dev so dashboards update quickly (defaults: 60s / 5s).
export OTEL_METRIC_EXPORT_INTERVAL=10000
export OTEL_LOGS_EXPORT_INTERVAL=5000

# --- Content capture (PRIVACY: review before enabling org-wide) ---
# Log prompt text on user_prompt events (otherwise prompt is <REDACTED>).
export OTEL_LOG_USER_PROMPTS=1
# Log tool parameters: Bash commands, file paths, MCP/skill/subagent names.
export OTEL_LOG_TOOL_DETAILS=1

# --- Full conversation transcripts (assistant replies + history) ENABLED ---
# Claude Code does NOT emit assistant responses as logs by default. This captures
# the entire Messages API request/response bodies. It writes the FULL conversation
# history (prompts, assistant text, tool args) into Loki; treat it as sensitive.
# Inline mode (=1): bodies land in Loki, truncated at 60 KB, visible in the dashboard.
export OTEL_LOG_RAW_API_BODIES=1
#   Alternative — on disk, untruncated (a body_ref path is logged instead of the body):
# export OTEL_LOG_RAW_API_BODIES=file:/tmp/claude-api-bodies

# --- Feature-run tracing (this repo's _shared/telemetry + .claude hooks) ---
# Per-feature-run spans, gate/commit events, and per-sub-agent transcripts are
# emitted by the skill chain itself to the collector's OTLP **HTTP** port (14318) —
# independent of the gRPC endpoint above. No env needed for that path. The Grafana
# "Feature Runs" dashboard reads it. To turn OFF per-sub-agent transcript ingestion
# (e.g. if you confirm Claude Code's native events carry agent_id — see README spike):
# export FEATURE_TELEMETRY_INGEST_TRANSCRIPTS=0
#
# OPTIONAL — Claude Code's own beta Traces (span hierarchy), complementary to the
# feature-run spans. Enable only after confirming the current var name in the docs
# (https://code.claude.com/docs/en/monitoring-usage); leave off if unsure:
# export OTEL_TRACES_EXPORTER=otlp

{
  "uid": "feature-runs",
  "title": "Feature Runs",
  "tags": ["feature", "claude-code", "trace"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "feature",
        "label": "Feature",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(feature)",
        "refresh": 2,
        "sort": 7,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "run_id",
        "label": "Feature run",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({feature=\"$feature\"}, run_id)",
        "refresh": 2,
        "sort": 8,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Run overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Sub-agents",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({run_id=\"$run_id\"} | event_type=\"subagent_stop\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Commits",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({run_id=\"$run_id\"} | event_type=\"commit\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Gate failures",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({run_id=\"$run_id\"} | event_type=\"gate\" | verdict=\"FAIL\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Spawns",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({run_id=\"$run_id\"} | event_type=\"spawn\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Initial prompt (intake)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{run_id=\"$run_id\"} | event_type=\"intake\"",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "row",
      "title": "Trace — stages & sub-agents (click a span to drill into what it did)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 7
    },
    {
      "type": "traces",
      "title": "Feature-run trace",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 11 },
      "id": 8,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ .feature.run_id = \"$run_id\" }",
          "limit": 50,
          "tableType": "traces"
        }
      ]
    },
    {
      "type": "row",
      "title": "Detail",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 9
    },
    {
      "type": "logs",
      "title": "Sub-agent timeline (spawn / start / stop)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 12, "x": 0, "y": 26 },
      "id": 10,
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Ascending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{run_id=\"$run_id\"} | event_type=~\"spawn|subagent_start|subagent_stop\"",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Gates (file-creation / validation, before next phase)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 11, "w": 12, "x": 12, "y": 26 },
      "id": 11,
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Ascending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{run_id=\"$run_id\"} | event_type=\"gate\"",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Commits (sha ↔ task ↔ phase — tied to the run)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "id": 12,
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Ascending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{run_id=\"$run_id\"} | event_type=\"commit\"",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Audit failures",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 45 },
      "id": 13,
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({run_id=\"$run_id\"} | event_type=\"audit_result\" | verdict=\"fail\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Audit results",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 49 },
      "id": 14,
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Ascending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{run_id=\"$run_id\"} | event_type=\"audit_result\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
